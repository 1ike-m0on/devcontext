# DevContext Docker Compose configuration.
# Copy this file to .env and adjust values for your machine.

# The host directory that contains projects DevContext can scan.
# It is mounted to /workspace/projects inside the backend container.
DEVCONTEXT_PROJECTS_DIR=./workspace/projects

# LLM provider: mock, gemini, or deepseek.
DEVCONTEXT_LLM_PROVIDER=mock

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=60s

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT=120s

# Vector store: qdrant or jdbc.
# Docker Compose starts Qdrant and uses it by default.
DEVCONTEXT_VECTOR_PROVIDER=qdrant
QDRANT_API_KEY=
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT=10s
